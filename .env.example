# Agentic Arbitrage Factory - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# Reddit (Optional - uses web scraping if not provided)
# =============================================================================
# Get from: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# =============================================================================
# OpenAI (Optional - for enhanced analysis)
# =============================================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# =============================================================================
# Ahrefs (Optional - for keyword research)
# =============================================================================
# Get from: https://ahrefs.com/
AHREFS_API_KEY=your_ahrefs_api_key

# =============================================================================
# Cloudflare (Optional - for deployment)
# =============================================================================
# Get from: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# =============================================================================
# GitHub (Optional - for repository creation)
# =============================================================================
# Get from: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_github_token

# =============================================================================
# Database (Optional - defaults to SQLite)
# =============================================================================
# SQLite (default)
DATABASE_URL=sqlite:///data/factory.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/factory

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# =============================================================================
# Factory Configuration
# =============================================================================
# Maximum concurrent sites
MAX_CONCURRENT_SITES=50

# Discovery interval (hours)
DISCOVERY_INTERVAL_HOURS=24

# =============================================================================
# Development Settings
# =============================================================================
# Set to "true" to skip actual deployments (for testing)
DRY_RUN=false

# Set to "true" to use mock data only
USE_MOCK_DATA=false
